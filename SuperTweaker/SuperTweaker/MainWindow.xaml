<Window x:Class="SuperTweaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:SuperTweaker.Views"
        Title="SuperTweaker" Height="1040" Width="1800"
        MinHeight="900" MinWidth="1500"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/Icons/supertweaker-golden-icon.png"
        Background="{StaticResource BgDeepBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True">

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolVis"/>
  </Window.Resources>

  <Border CornerRadius="12" Background="{StaticResource BgDeepBrush}"
          BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="44"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- ===== Custom Title Bar ===== -->
      <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}"
              CornerRadius="12,12,0,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Logo + Title -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
            <Border Width="24" Height="24" CornerRadius="6"
                    Background="{StaticResource AccentBrush}" Margin="0,0,10,0">
              <TextBlock Text="S" FontSize="13" FontWeight="Bold" Foreground="White"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="SuperTweaker" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            <Border Margin="10,0,0,0" CornerRadius="4"
                    Background="#1A1870" Padding="6,2">
              <TextBlock x:Name="OsBadgeText" Text="Windows 11" FontSize="10"
                         Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
            </Border>
          </StackPanel>

          <!-- Admin indicator -->
          <StackPanel Grid.Column="1" Orientation="Horizontal"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse Width="7" Height="7" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,6,0"/>
            <TextBlock Text="Running as Administrator" FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}"/>
          </StackPanel>

          <!-- Window controls -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
            <Button x:Name="MinBtn" Content="─" Width="36" Height="36"
                    Style="{StaticResource GhostButton}" Padding="0"
                    Click="MinBtn_Click" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}"/>
            <Button x:Name="CloseBtn" Content="✕" Width="36" Height="36"
                    Style="{StaticResource GhostButton}" Padding="0"
                    Click="CloseBtn_Click" BorderThickness="0"
                    Foreground="{StaticResource TextSecondaryBrush}"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- ===== Body: Side Nav + Content ===== -->
      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Side Navigation -->
        <Border Grid.Column="0" Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                CornerRadius="0,0,0,12">
          <StackPanel Margin="12,20,12,20">

            <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="16,0,0,16"/>

            <RadioButton x:Name="NavDashboard" Style="{StaticResource NavButton}"
                         IsChecked="True" Checked="NavButton_Checked" Tag="Dashboard">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="⬡" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Dashboard"/>
              </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavPerformance" Style="{StaticResource NavButton}"
                         Checked="NavButton_Checked" Tag="Performance">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Performance"/>
              </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavApps" Style="{StaticResource NavButton}"
                         Checked="NavButton_Checked" Tag="Apps">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Apps &amp; Software"/>
              </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavUpdates" Style="{StaticResource NavButton}"
                         Checked="NavButton_Checked" Tag="Updates">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛡" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Windows Update"/>
              </StackPanel>
            </RadioButton>

            <RadioButton x:Name="NavSpoofer" Style="{StaticResource NavButton}"
                         Checked="NavButton_Checked" Tag="Spoofer">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="🎭" FontSize="14" Margin="0,0,8,0"/>
                <TextBlock Text="Spoofer"/>
              </StackPanel>
            </RadioButton>

            <!-- Spacer -->
            <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="8,16"/>

            <!-- Version info -->
            <TextBlock Text="v1.0.0 — 2026" FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" Margin="0,4"/>
          </StackPanel>
        </Border>

        <!-- Tab Content -->
        <Border Grid.Column="1" Padding="26">
          <Grid>
            <views:DashboardTab  x:Name="TabDashboard"  Visibility="Visible"/>
            <views:PerformanceTab x:Name="TabPerformance" Visibility="Collapsed"/>
            <views:AppsTab       x:Name="TabApps"       Visibility="Collapsed"/>
            <views:UpdatesTab    x:Name="TabUpdates"    Visibility="Collapsed"/>
            <views:SpooferTab    x:Name="TabSpoofer"    Visibility="Collapsed"/>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </Border>
</Window>

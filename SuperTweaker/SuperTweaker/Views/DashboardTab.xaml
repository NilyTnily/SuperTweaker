<UserControl x:Class="SuperTweaker.Views.DashboardTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>

      <!-- Page Title -->
      <TextBlock Text="System Dashboard" FontSize="22" FontWeight="Bold"
                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
      <TextBlock Text="System health, hardware telemetry, and pre-flight checks before applying tweaks."
                 FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,24"/>

      <!-- OS + CPU + Storage Row -->
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- OS Card -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Operating System" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="OsCaption" Text="—" Style="{StaticResource ValueText}"
                       FontSize="15" FontWeight="Bold" TextWrapping="Wrap"/>
            <TextBlock x:Name="OsBuild" Text="Build —" Style="{StaticResource LabelText}" Margin="0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
              <Border x:Name="OsVersionBadge" CornerRadius="10" Padding="8,3"
                      Background="#1A1870">
                <TextBlock x:Name="OsVersionText" Text="Windows 11" FontSize="11"
                           Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
              </Border>
              <Border x:Name="OsEditionBadge" CornerRadius="10" Padding="8,3"
                      Margin="6,0,0,0" Background="#0A2A1A">
                <TextBlock x:Name="OsEditionText" Text="Pro" FontSize="11"
                           Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- CPU Card -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Processor" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="CpuName" Text="—" Style="{StaticResource ValueText}"
                       TextWrapping="Wrap" FontSize="12"/>
            <TextBlock x:Name="RamInfo" Text="RAM: —" Style="{StaticResource LabelText}"
                       Margin="0,6,0,0"/>
            <TextBlock x:Name="CpuCoreInfo" Text="Cores: —" Style="{StaticResource LabelText}"
                       Margin="0,2"/>
            <TextBlock x:Name="CpuClockInfo" Text="Max Clock: —" Style="{StaticResource LabelText}"
                       Margin="0,2"/>
          </StackPanel>
        </Border>

        <!-- Disk Card -->
        <Border Grid.Column="4" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Storage" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="DiskInfo" Text="—" Style="{StaticResource ValueText}"
                       FontSize="12" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- GPU + Motherboard + Platform Row -->
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Graphics" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="GpuName" Text="—" Style="{StaticResource ValueText}"
                       FontSize="12" TextWrapping="Wrap"/>
            <TextBlock x:Name="GpuVramInfo" Text="VRAM: —" Style="{StaticResource LabelText}"
                       Margin="0,6,0,0"/>
            <TextBlock x:Name="GpuDriverInfo" Text="Driver: —" Style="{StaticResource LabelText}"
                       Margin="0,2"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Motherboard" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="MotherboardKindText" Text="Kind: —" Style="{StaticResource ValueText}"
                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
            <TextBlock x:Name="MotherboardProductText" Text="—" Style="{StaticResource ValueText}"
                       FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
            <TextBlock x:Name="MotherboardVersionLine" Text="Revision: —" Style="{StaticResource LabelText}"
                       Margin="0,6,0,0" TextWrapping="Wrap"/>
            <TextBlock x:Name="MotherboardSerialLine" Text="Serial: —" Style="{StaticResource LabelText}"
                       Margin="0,2" TextWrapping="Wrap"/>
            <TextBlock x:Name="MotherboardPartLine" Text="Part number: —" Style="{StaticResource LabelText}"
                       Margin="0,2" TextWrapping="Wrap"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="4" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Text="Platform" Style="{StaticResource LabelText}" Margin="0,0,0,8"/>
            <TextBlock x:Name="ArchInfo" Text="x64" Style="{StaticResource ValueText}" FontSize="14"/>
            <TextBlock x:Name="WindowsFamilyInfo" Text="Windows family: —" Style="{StaticResource LabelText}" Margin="0,6,0,0"/>
            <TextBlock x:Name="EditionInfo" Text="Edition: —" Style="{StaticResource LabelText}" Margin="0,2"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- Security Checks Row -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Security &amp; Compatibility Checks"
                     Style="{StaticResource SectionHeader}"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Admin -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
              <TextBlock Text="Admin Privileges" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
              <Border x:Name="AdminBadge">
                <TextBlock x:Name="AdminText" Text="✓ Elevated" FontSize="11" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>

            <!-- Secure Boot -->
            <StackPanel Grid.Column="1" Margin="0,0,12,0">
              <TextBlock Text="Secure Boot" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
              <Border x:Name="SecureBootBadge">
                <TextBlock x:Name="SecureBootText" Text="—" FontSize="11" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>

            <!-- VBS -->
            <StackPanel Grid.Column="2" Margin="0,0,12,0">
              <TextBlock Text="VBS / Memory Integrity" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
              <Border x:Name="VbsBadge">
                <TextBlock x:Name="VbsText" Text="—" FontSize="11" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>

            <!-- Tamper Protection -->
            <StackPanel Grid.Column="3">
              <TextBlock Text="Tamper Protection" Style="{StaticResource LabelText}" Margin="0,0,0,6"/>
              <Border x:Name="TamperBadge">
                <TextBlock x:Name="TamperText" Text="—" FontSize="11" FontWeight="SemiBold"/>
              </Border>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Restore Points -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0">
            <TextBlock Text="Backup &amp; Restore Points"
                       Style="{StaticResource SectionHeader}"/>
            <TextBlock x:Name="RestorePointList"
                       Text="No SuperTweaker restore points found."
                       Style="{StaticResource LabelText}" TextWrapping="Wrap"/>
            <TextBlock Text="Always create a restore point before applying any tweaks."
                       FontSize="11" Foreground="{StaticResource AccentOrangeBrush}"
                       Margin="0,6,0,0"/>
          </StackPanel>
          <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
            <Button Content="Open System Image Backup"
                    Style="{StaticResource GhostButton}"
                    Click="OpenBackupCenter_Click" Margin="0,0,0,8"/>
            <Button Content="Open Restore Wizard"
                    Style="{StaticResource GhostButton}"
                    Click="OpenRestoreWizard_Click"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Log output -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="Console" Style="{StaticResource SectionHeader}"/>
          <TextBox x:Name="ConsoleBox" Style="{StaticResource LogBox}"
                   Height="120"
                   Text="SuperTweaker initialized. Ready.&#x0a;"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>

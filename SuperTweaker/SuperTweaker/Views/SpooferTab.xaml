<UserControl x:Class="SuperTweaker.Views.SpooferTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel>

      <!-- Title -->
      <TextBlock Text="Spoofer" FontSize="22" FontWeight="Bold"
                 Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
      <TextBlock Text="Change MAC address (NIC-level) and user-mode HWID identifiers."
                 FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"
                 TextWrapping="Wrap"/>
      <Border Margin="0,4,0,8" CornerRadius="8" Background="#1A1870" Padding="8,3" HorizontalAlignment="Left">
        <TextBlock x:Name="OsScopeText" Text="OS scope: detecting..." FontSize="11"
                   Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
      </Border>
      <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,20"
                 TextWrapping="Wrap">
        Scope: NetworkAddress registry key (MAC) · MachineGuid · HwProfileGuid · SqmMachineId · ProductId · SusClientId.
        Kernel/SMBIOS/EFI spoofing is outside the scope of this tool (requires signed kernel drivers).
      </TextBlock>

      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="Backup Wizard (Spoofer Safety)" Style="{StaticResource SectionHeader}"/>
          <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
            1) Click Create Backup Snapshot before spoofing to save current MAC + HWID values.<LineBreak/>
            2) Apply spoof operations.<LineBreak/>
            3) If needed, click Revert From Latest Snapshot to roll back custom spoof changes.
          </TextBlock>
          <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="CreateSpooferBackupBtn" Content="💾  Create Backup Snapshot"
                    Style="{StaticResource OrangeButton}" Margin="0,0,10,0"
                    Click="CreateSpooferBackup_Click"/>
            <Button x:Name="RevertSpooferBackupBtn" Content="↩  Revert From Latest Snapshot"
                    Style="{StaticResource GhostButton}" Click="RevertSpooferBackup_Click"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- ===== MAC SPOOFER ===== -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="MAC Address Spoofer" Style="{StaticResource SectionHeader}"/>

          <!-- List header -->
          <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Adapter"          Style="{StaticResource LabelText}"/>
            <TextBlock Grid.Column="1" Text="Current MAC"      Style="{StaticResource LabelText}"/>
            <TextBlock Grid.Column="2" Text="Registry (spoofed)" Style="{StaticResource LabelText}"/>
            <TextBlock Grid.Column="3" Text="Status"           Style="{StaticResource LabelText}"/>
          </Grid>
          <Rectangle Height="1" Fill="{StaticResource BorderBrush}" Margin="0,0,0,8"/>

          <StackPanel x:Name="NicListPanel"/>

          <!-- Input Row -->
          <Grid Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="2*"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="150"/>
              <ColumnDefinition Width="12"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="8"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="NicCombo" Grid.Column="0" Height="36"
                      Background="{StaticResource BgCardBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderBrush="{StaticResource BorderBrush}"/>

            <TextBox x:Name="NewMacBox" Grid.Column="2" Height="36"
                     Background="{StaticResource BgCardBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                     Padding="10,8" FontFamily="Cascadia Code, Consolas, Courier New"
                     Text="AA:BB:CC:DD:EE:FF" VerticalContentAlignment="Center"/>

            <Button Grid.Column="4" Content="🎲  Random"
                    Style="{StaticResource GhostButton}" Height="36"
                    Click="RandomMac_Click"/>
            <Button Grid.Column="6" Content="Apply MAC"
                    Style="{StaticResource PrimaryButton}" Height="36"
                    Click="ApplyMac_Click"/>
            <Button Grid.Column="8" Content="Restore Original"
                    Style="{StaticResource GhostButton}" Height="36"
                    Click="RestoreMac_Click"/>
          </Grid>

          <Button Content="↻  Refresh Adapters" Style="{StaticResource GhostButton}"
                  Margin="0,10,0,0" HorizontalAlignment="Left"
                  Click="RefreshNics_Click"/>
        </StackPanel>
      </Border>

      <!-- ===== HWID SPOOFER ===== -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="HWID Identifiers (User-Mode)" Style="{StaticResource SectionHeader}"/>

          <Grid x:Name="HwidGrid" Margin="0,0,0,16"/>

          <CheckBox x:Name="RandomNameChk" Style="{StaticResource ModernCheckBox}"
                    Content="Also randomise computer hostname (effective after reboot)"
                    Margin="0,0,0,12"/>

          <StackPanel Orientation="Horizontal">
            <Button x:Name="SpoofHwidBtn"
                    Content="🎭  Spoof HWID Identifiers"
                    Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"
                    Click="SpoofHwid_Click"/>
            <Button x:Name="RestoreHwidBtn"
                    Content="↩  Restore Original HWID"
                    Style="{StaticResource GhostButton}" IsEnabled="False"
                    Click="RestoreHwid_Click"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Log -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <TextBlock Text="Spoofer Log" Style="{StaticResource SectionHeader}"/>
          <TextBox x:Name="LogBox" Style="{StaticResource LogBox}" Height="130"/>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
